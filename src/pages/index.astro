---
import { Image } from 'astro:assets';

import Layout from '../layouts/Layout.astro';
import catMapsImage from '../assets/cat-maps.jpg';
import graduateProjectImage from '../assets/graduate-project.jpg';
import nichakarnPortImage from '../assets/nichakarn-port.jpg';
import quarantineCheckerImage from '../assets/quarantine-checker.jpg';
---

<Layout>
	<section class="hero-section">
		<p class="gradient-text">Hello,</p>
		<h1>
			I'm Panyawat Kaedpol
			<br>
			A frontend developer who is passionate about building user-friendly, interactive web experiences.
		</h1>
		<div class="buttons">
			<a class="nes-btn" href="til">TIL</a>
			<a class="nes-btn" href="#contact">CONTACT</a>
		</div>
	</section>
	<section>
		<div class="projects">
			<div class="project nes-container is-dark is-rounded">
				<h2>Cat Maps</h2>
				<Image src={catMapsImage} alt="cat maps" />
			</div>
			<div class="project nes-container is-dark is-rounded">
				<h2>Graduate Project</h2>
				<Image src={graduateProjectImage} alt="graduate project" />
			</div>
			<div class="project nes-container is-dark is-rounded">
				<h2>Nichakarn Port</h2>
				<Image src={nichakarnPortImage} alt="nichakarn-port" />
			</div>
			<div class="project nes-container is-dark is-rounded">
				<h2>Quarantine Checker</h2>
				<Image src={quarantineCheckerImage} alt="quarantine checker" />
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero-section {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: start;
		justify-content: center;
		min-height: 50vh;
		padding-bottom: 4rem;

		p {
			font-size: clamp(3.5rem, 9vw , 4rem);
		}

		h1 {
			font-size: clamp(1.5rem, 3vw , 2rem);
			line-height: 2;
		}

		.buttons {
			display: flex;
			gap: 1rem;
		}
	}



	.projects {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 450px), 1fr));
		gap: 1rem;

		.project {
			position: relative;
			aspect-ratio: 1 / 1;

			& > img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			&:hover h2 {
				opacity: 1;
			}

			&:hover:before {
				opacity: 1;
			}

			h2 {
				font-weight: normal;
				opacity: 0;
				bottom: 0;
				left: 0;
				padding: 2rem;
				font-size: 2rem;
				transition: opacity 250ms;
				margin-bottom: 0;
				position: absolute;
			}

			&:before {
				content: '';
				position: absolute;
				inset: 0.5rem;
				background: linear-gradient(to bottom, hsla(270, 10%, 4%, 0) 0%, hsla(270, 10%, 4%, 0.75) 100%);
				opacity: 0;
				transition: opacity 250ms;
			}
		}
	}
</style>
